<view class="profile-page">
  <nav title-text="我的" />

  <view class="profile-content">
    <view class="profile-card">
      <view class="avatar">AU</view>
      <view>
        <view class="name">黄金价格关注助手</view>
        <view class="openid">身份类型：{{openidSource}}</view>
        <view class="openid">当前用户：{{openid}}</view>
      </view>
    </view>

    <view class="setting-card">
      <view wx:for="{{items}}" wx:key="label" class="setting-row">
        <view class="setting-label">{{item.label}}</view>
        <view class="setting-value">{{item.value}}</view>
      </view>
    </view>

    <view class="notice">
      本服务仅提供黄金价格信息与提醒功能，不构成投资建议。
    </view>
  </view>
</view>
